<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AstroLauncher.ViewModels"
             xmlns:viewModels="clr-namespace:AstroLauncher.ViewModels"
             x:DataType="viewModels:SettingsViewModel"
             x:CompileBindings="True"
             x:Class="AstroLauncher.Views.SettingsView">
    
    <StackPanel Margin="12" Spacing="10">
        <TextBlock Text="Settings" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" 
                   HorizontalAlignment="Left"/>
        
        <TextBlock Text="Customize your launcher experience" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" 
                   HorizontalAlignment="Left"/>
    </StackPanel>
</UserControl>
